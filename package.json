{
  "name": "@motiongen/sdk",
  "version": "0.1.0",
  "description": "MotionGen V3 - Lottie JSON Builder SDK",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "node dist/tests/visual-tests.js",
    "test:update": "UPDATE_GOLDEN=1 node dist/tests/visual-tests.js",
    "test:build": "tsc && node dist/tests/visual-tests.js",
    "test:build:update": "UPDATE_GOLDEN=1 tsc && node dist/tests/visual-tests.js",
    "example": "tsc && node dist/example.js",
    "serve": "node serve.js",
    "view": "node serve.js",
    "dev": "tsc --watch",
    "test:sandbox-e2e": "tsc && node dist/tests/sandbox-e2e.js",
    "test:renderer-e2e": "tsc && node dist/tests/render-e2e.js",
    "test:director-e2e": "tsc && node dist/tests/director-e2e.js",
    "test:animator-e2e": "tsc && node dist/tests/animator-e2e.js",
    "test:critic-e2e": "tsc && node dist/tests/critic-e2e.js",
    "test:orchestrator-e2e": "tsc && node dist/tests/orchestrator-e2e.js",
    "test:asset-processor-e2e": "tsc && node dist/tests/assetProcessor-e2e.js"
  },
  "keywords": [
    "lottie",
    "animation",
    "motion",
    "sdk"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/cheerio": "^1.0.0",
    "@types/node": "^20.0.0",
    "@types/svgo": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@langchain/langgraph": "^1.0.2",
    "cheerio": "^1.1.2",
    "puppeteer": "^24.31.0",
    "svgo": "^4.0.0",
    "vm2": "^3.10.0"
  }
}
